# ---- Praxis 环境变量模板 ----
# 复制为 .env.local 后按需填写。.env* 已被 gitignore，绝不会进仓库。

# 推荐：代理模式。浏览器只跟你自己的 /api/gemini 通信，
# Gemini key 放在 Vercel 服务端环境变量里（见下方"服务端"部分），
# 永远不出现在前端代码或用户浏览器中。
VITE_USE_PROXY=1

# 代理模式的访问口令（可选但强烈建议）。前后端各配一份、值相同：
# 前端把它放进 x-app-token 请求头，服务端校验。不配则任何人都能调用你的代理。
VITE_APP_ACCESS_TOKEN=

# 仅本地开发直连 Gemini 时才需要（不推荐用于任何部署——
# VITE_ 前缀的变量会被打包进前端 JS，公开部署等于泄露 key）。
# VITE_GEMINI_API_KEY=

# 可选：Supabase 云端存储（不配则用本地 IndexedDB）。
# 注意 anon key 会随前端请求暴露，多人使用前必须在 Supabase 配好 RLS。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- 服务端（Vercel 项目环境变量，不写在本文件）----
# GEMINI_API_KEY      真正的 Gemini key，只存在于 Vercel 服务端
# APP_ACCESS_TOKEN    与 VITE_APP_ACCESS_TOKEN 相同的口令
