# ---- Praxis environment template ----
# Copy to .env.local and fill in what you need. .env* is gitignored and
# never enters the repository.

# Recommended: proxy mode. The browser only talks to your own /api/generate;
# the Gemini key lives in Vercel server-side env vars (see "Server-side"
# below) and never appears in frontend code or the user's browser.
VITE_USE_PROXY=1

# Proxy access passphrase (optional but strongly recommended). Set the same
# value on both sides: the frontend sends it as the x-app-token header, the
# server verifies it. Without it, anyone can burn your quota through the proxy.
VITE_APP_ACCESS_TOKEN=

# Only for local development calling Gemini directly (NOT recommended for any
# deployment — VITE_-prefixed variables are compiled into the public JS
# bundle; setting this on a public deployment leaks your key).
# VITE_GEMINI_API_KEY=

# Optional: Supabase cloud storage (falls back to local IndexedDB when unset).
# Note the anon key is exposed with every frontend request — configure RLS in
# Supabase before sharing a deployment with others.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Server-side (Vercel project env vars — NOT in this file) ----
# GEMINI_API_KEY      the real Gemini key, server-side only
# APP_ACCESS_TOKEN    same passphrase as VITE_APP_ACCESS_TOKEN
